<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - Mini Training Center
    </title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/MiniTrainingCenterCatalog.Mvc.styles.css"
          asp-append-version="true" />

</head>

<body>

<header>

<nav class="navbar navbar-expand-sm navbar-dark bg-dark">

<div class="container-fluid">

<a class="navbar-brand"
   asp-controller="Home"
   asp-action="Index">

Mini Training Center

</a>

<button class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target=".navbar-collapse">

<span class="navbar-toggler-icon"></span>

</button>

<div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

<ul class="navbar-nav flex-grow-1">

<li class="nav-item">

<a class="nav-link text-light"
   asp-controller="Home"
   asp-action="Index">

Home

</a>

</li>

<li class="nav-item">

<a class="nav-link text-light"
   asp-controller="Dashboard"
   asp-action="Index">

Dashboard

</a>

</li>

<li class="nav-item">

<a class="nav-link text-light"
   asp-controller="Courses"
   asp-action="Index">

Courses

</a>

</li>

@if(User.IsInRole("Admin"))
{

<li class="nav-item">

<a class="nav-link text-light"
   asp-controller="Courses"
   asp-action="Create">

Create Course

</a>

</li>

<li class="nav-item">

<a class="nav-link text-light"
   asp-controller="Courses"
   asp-action="Trash">

Archived

</a>

</li>

<li class="nav-item">

<a class="nav-link text-light"
   asp-controller="Audit"
   asp-action="Index">

Audit Logs

</a>

</li>

}

<li class="nav-item">

<a class="nav-link text-light"
   asp-controller="Courses"
   asp-action="Stats">

Statistics

</a>

</li>

<li class="nav-item">

<a class="nav-link text-light"
   asp-controller="Enrollments"
   asp-action="Create">

Enrollment

</a>

</li>

</ul>

<ul class="navbar-nav">

@if(User.Identity!.IsAuthenticated)
{

<li class="nav-item">

<span class="navbar-text text-white me-3">

Hello @User.Identity.Name

</span>

</li>

<li class="nav-item">

<form asp-controller="Account"
      asp-action="Logout"
      method="post">

@Html.AntiForgeryToken()

<button class="btn btn-outline-light">

Logout

</button>

</form>

</li>

}
else
{

<li class="nav-item">

<a class="btn btn-primary me-2"
   asp-controller="Account"
   asp-action="Login">

Login

</a>

</li>

<li class="nav-item">

<a class="btn btn-success"
   asp-controller="Account"
   asp-action="Register">

Register

</a>

</li>

}

</ul>

</div>

</div>

</nav>

</header>

<div class="container mt-3">

@if (TempData["Success"] != null)
{
<div class="alert alert-success">
@TempData["Success"]
</div>
}

@if (TempData["Error"] != null)
{
<div class="alert alert-danger">
@TempData["Error"]
</div>
}

<main role="main">

@RenderBody()

</main>

</div>

<footer class="border-top footer text-muted mt-4">

<div class="container">

© @DateTime.Now.Year - Mini Training Center

</div>

</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<script src="~/js/site.js"
        asp-append-version="true"></script>

@await RenderSectionAsync(
    "Scripts",
    required: false)

</body>

</html>