@model MiniTrainingCenterCatalog.Mvc.ViewModels.CourseCreateViewModel

<h2>Create Course</h2>

<form method="post">

    <div class="mb-3">

        <label asp-for="CourseName"></label>

        <input asp-for="CourseName"
               class="form-control" />

        <span asp-validation-for="CourseName"
              class="text-danger"></span>

    </div>

    <div class="mb-3">

        <label asp-for="Instructor"></label>

        <input asp-for="Instructor"
               class="form-control" />

        <span asp-validation-for="Instructor"
              class="text-danger"></span>

    </div>

    <div class="mb-3">

        <label asp-for="Fee"></label>

        <input asp-for="Fee"
               class="form-control" />

        <span asp-validation-for="Fee"
              class="text-danger"></span>

    </div>
    <div class="alert alert-warning">

    Fill in all course information before submitting.

</div>

    <div class="mb-3">

        <label asp-for="Capacity"></label>

        <input asp-for="Capacity"
               class="form-control" />

        <span asp-validation-for="Capacity"
              class="text-danger"></span>

    </div>

    <button class="btn btn-success">
        Create
    </button>

</form>