@model MiniTrainingCenterCatalog.Mvc.ViewModels.CourseSearchViewModel

<h2>Search Course</h2>

<form method="get">

    <div class="mb-3">
        <label>Course Name</label>
        <input asp-for="Keyword"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Instructor</label>
        <input asp-for="Instructor"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Minimum Fee</label>
        <input asp-for="MinFee"
               class="form-control" />
    </div>

    <button class="btn btn-primary">
        Search
    </button>

</form>

@if(ViewBag.Count != null)
{
    <div class="alert alert-info mt-3">

        Found @ViewBag.Count course(s)

    </div>

    var results =
        ViewBag.Results as IEnumerable<MiniTrainingCenterCatalog.Mvc.ViewModels.CourseListItemViewModel>;

    if (results != null && results.Any())
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Course</th>
                    <th>Instructor</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in results)
            {
                <tr>
                    <td>@item.CourseName</td>
                    <td>@item.Instructor</td>
                    <td>@item.Status</td>
                    <td>
                        <a asp-action="Detail"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-info">
                            Detail
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-warning">
            No matching courses found.
        </div>
    }
}
